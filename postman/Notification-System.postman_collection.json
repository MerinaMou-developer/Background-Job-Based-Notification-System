{
  "info": {
    "name": "Notification System API",
    "description": "Import into Postman. Set `base_url` to local (http://127.0.0.1:8000) or live Render URL. Run Register → Login first; Login saves `access_token` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "notification_id",
      "value": "1"
    },
    {
      "key": "scheduled_time",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reviewer@example.com\",\n  \"password\": \"ReviewPass123!\",\n  \"password_confirm\": \"ReviewPass123!\",\n  \"first_name\": \"Reviewer\",\n  \"last_name\": \"Test\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register/"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reviewer@example.com\",\n  \"password\": \"ReviewPass123!\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login/"
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"<paste_refresh_from_login>\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/refresh/"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/me/"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Create notification (3 min ahead)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const d = new Date(Date.now() + 3 * 60 * 1000);",
                  "const p = (n) => String(n).padStart(2, '0');",
                  "const scheduled = `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}:00+06:00`;",
                  "pm.collectionVariables.set('scheduled_time', scheduled);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('notification_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Meeting reminder\",\n  \"message\": \"Your standup starts soon.\",\n  \"scheduled_time\": \"{{scheduled_time}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/notifications/"
          }
        },
        {
          "name": "List notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/notifications/"
          }
        },
        {
          "name": "Notification detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/notifications/{{notification_id}}/"
          }
        },
        {
          "name": "Retry notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/notifications/{{notification_id}}/retry/"
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health/"
      }
    }
  ]
}
