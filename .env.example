# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL) — use DB_HOST=db when running via Docker Compose
DB_HOST=localhost
DB_NAME=notification_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
# Docker Compose maps Postgres to host port 5433 (see docker-compose.yml)
# DB_HOST=localhost and DB_PORT=5433 when connecting from your machine to Docker db

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
FLOWER_PORT=5555

# Timezone (BDT)
DJANGO_TIME_ZONE=Asia/Dhaka

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_USE_TLS=true
EMAIL_FROM=your@gmail.com
